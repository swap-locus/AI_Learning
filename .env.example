# Copy this file to .env and fill in your real keys.
# .env is gitignored — never commit it.

# Required by all projects
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required by AI_Bot
GROQ_API_KEY=gsk_your-key-here
GEMINI_API_KEY=AIzaSy-your-key-here

# Required by JupyterNotebook (RAG series)
VOYAGE_API_KEY=pa-your-key-here

# Required by MCP_Learning
CLAUDE_MODEL=claude-sonnet-4-6
# Spawn the MCP server via `uv run` (1) instead of `python` (0)
USE_UV=1

# Claude_Chatbot optional overrides
# PORT=8080
# VERIFY_SSL=true
